# Primární verze — `make up` bez argumentu nahodí ji (jeden zdroj pravdy).
DEFAULT_PS=ps91

# Sdílené hodnoty napříč PS verzemi (instalace).
PS_DEV_MODE=1
PS_LANGUAGE=cs
PS_COUNTRY=CZ
PS_ALL_LANGUAGES=0
PS_FOLDER_ADMIN=admin1234
ADMIN_MAIL=demo@prestashop.com
ADMIN_PASSWD=prestashop_demo

# Packeta secrets pro `make configure` (fáze 2) — doplň z Packeta účtu (dev = PROD API!).
PACKETERY_APIPASS=
PACKETERY_ESHOP_ID=

# Stage SOAP/WSDL URL pro `make api-stage` (override _PACKETERY_SOAP_WSDL_URL_). Doplň stage URL; prázdné = jen prod.
PACKETERY_SOAP_STAGE_WSDL_URL=
