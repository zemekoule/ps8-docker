services:

  adminer:
    image: adminer
    restart: always
    ports:
      - 8080:8080

  prestashop:
    container_name: prestashop
    image: prestashop/prestashop:latest # Latest stable version of the PrestaShop, to see all available images go to ...
    restart: unless-stopped
    depends_on:
      - mysql
    ports:
      - 8080:80
    environment:
      DB_SERVER: some-mysql
      DB_NAME: prestashop
      DB_USER: root
      DB_PASSWD: admin
    networks:
      - prestashop_network

  web-php-8.4:
    build:
      context: .
      dockerfile: php84.Dockerfile
      args:
        ARG_UID: ${ENV_UID:-1000}
        ARG_GID: ${ENV_GID:-1000}
    links:
      - db
    ports:
      - 80:80
      - 443:443
    extra_hosts:
      # define host.docker.internal for Linux; it exists automatically on Windows and Mac
      # along with xdebug.client_host enables debugging from PhpStorm
      - host.docker.internal:host-gateway

    volumes:
      - ./src:/var/www/app
      - ./php.ini:/usr/local/etc/php/conf.d/php.ini
      - ./virtualhost.conf:/etc/apache2/sites-available/000-default.conf

      # to get rid of AH00558: apache2: Could not reliably determine the server's fully qualified domain name... Set the 'ServerName' directive globally to suppress this message
      - ./apache2.conf:/etc/apache2/apache2.conf

#      - ./ports.conf:/etc/apache2/ports.conf

# /etc/hosts must not be mounted, because it would override the extra_hosts above
#      - ./hosts:/etc/hosts:ro

    working_dir: /var/www/app
    environment:
      XDEBUG_CONFIG: "client_host=host.docker.internal" # this can be replaced with a line in Dockerfile
      NETTE_DEBUG: 1

      # PePa's value in PhpStorm Settings/PHP/Servers; useful when debugging CLI scripts from within the container, not from PhpStorm
      PHP_IDE_CONFIG: "serverName=shoptet-log-parser.local"

  mysql:
    user: "${CURRENT_UID:-1000}:${CURRENT_GID:-1000}"
    container_name: some-mysql
    image: mysql:5.7
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: admin
      MYSQL_DATABASE: prestashop
    volumes:
      - ./db:/var/lib/mysql
    networks:
      - prestashop_network

  db:
    image: mariadb:10.6
    environment:
      - MARIADB_ROOT_PASSWORD=asdf
      - TZ=Europe/Prague
    ports:
      - 3308:3306

#    # this enables logging all queries to a file in the db directory - comment out this whole line to disable
#    command: mysqld --general-log=1 --general-log-file=general-log.log

networks:
  prestashop_network:
